{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/honoraires.html",
      "destination": "/methode",
      "permanent": true
    },
    {
      "source": "/honoraires",
      "destination": "/methode",
      "permanent": true
    },
    {
      "source": "/en/honoraires.html",
      "destination": "/en/approach",
      "permanent": true
    },
    {
      "source": "/en/honoraires",
      "destination": "/en/approach",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    }
  ]
}
